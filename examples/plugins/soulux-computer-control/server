#!/usr/bin/env python3
"""SoulUX Computer Control — MCP stdio server (T2).

ADR-0048 T2 ships the read tools:

  - computer_screenshot.v1   — capture the visible screen via macOS
                               screencapture, save under
                               ~/.forest/screenshots/, return path +
                               size + format
  - computer_read_clipboard.v1 — read the current clipboard contents
                               via macOS pbpaste, return text

Both tools are read_only (no operator approval required by the
plugin's requires_human_approval map). Posture clamps still apply
via Forest's PostureGateStep — but read_only bypasses posture
unconditionally per ADR-0048 Decision 4 + B160 coverage tests.

Wire protocol: Forest's mcp_call.v1 dispatches as a single-shot
subprocess per call (see src/forest_soul_forge/tools/builtin/
mcp_call.py:230-260). The contract:

  - Read ONE JSON-RPC line from stdin
  - Method: 'tools/call', params: {name, arguments}
  - Write ONE JSON-RPC response line to stdout
  - Exit 0

Single-file by design: zero non-stdlib imports so the operator's
sha256 pin stays stable when no upstream packages move.
"""
from __future__ import annotations

import base64
import datetime as _dt
import json
import os
import platform
import subprocess
import sys
import tempfile
from pathlib import Path


# ---------------------------------------------------------------------------
# Tool implementations
# ---------------------------------------------------------------------------

SCREENSHOT_DIR = Path.home() / ".forest" / "screenshots"


def _ts() -> str:
    return _dt.datetime.now(_dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def _macos_only(tool_name: str) -> dict:
    """Build a JSON-RPC error result for non-macOS platforms."""
    return {
        "isError": True,
        "error": {
            "code": "platform_unsupported",
            "message": (
                f"{tool_name} is macOS-only. Detected platform: "
                f"{platform.system()}. The soulux-computer-control "
                f"plugin v0.1 wraps macOS-specific binaries "
                f"(screencapture, pbpaste); a future tranche will add "
                f"Linux/Windows fallbacks."
            ),
        },
    }


def computer_screenshot(args: dict) -> dict:
    """Capture the visible screen.

    Args:
      filename: optional filename suffix (default: timestamp).
      include_base64: if True, embed the PNG bytes in the response
                      as base64 in addition to writing to disk. The
                      bytes inflate the response — use sparingly.
                      Default False; the caller reads from path.

    Returns:
      { path, size_bytes, format: 'png', captured_at, base64? }
    """
    if platform.system() != "Darwin":
        return _macos_only("computer_screenshot")

    SCREENSHOT_DIR.mkdir(parents=True, exist_ok=True)
    suffix = (args.get("filename") or _ts()).strip()
    # Defense in depth: forbid path traversal in operator-supplied name.
    if "/" in suffix or ".." in suffix:
        return {
            "isError": True,
            "error": {
                "code": "bad_filename",
                "message": "filename must not contain '/' or '..'",
            },
        }
    out_path = SCREENSHOT_DIR / f"{suffix}.png"

    # screencapture flags:
    #   -x = no shutter sound
    #   -t png = explicit PNG format
    # No -i (interactive) and no -w (window picker) — those would
    # block on user input and break the stateless tool-call model.
    try:
        proc = subprocess.run(
            ["screencapture", "-x", "-t", "png", str(out_path)],
            capture_output=True,
            timeout=10,
        )
    except subprocess.TimeoutExpired:
        return {
            "isError": True,
            "error": {
                "code": "screencapture_timeout",
                "message": "screencapture did not return within 10s",
            },
        }
    if proc.returncode != 0:
        return {
            "isError": True,
            "error": {
                "code": "screencapture_failed",
                "message": (
                    proc.stderr.decode("utf-8", errors="replace")[:200]
                    or f"screencapture exited {proc.returncode}"
                ),
            },
        }

    if not out_path.exists():
        return {
            "isError": True,
            "error": {
                "code": "screencapture_no_output",
                "message": (
                    "screencapture returned 0 but the output PNG was "
                    "not written. macOS may have denied screen-recording "
                    "permission to the calling process. Grant Screen "
                    "Recording in System Settings → Privacy & Security."
                ),
            },
        }

    size_bytes = out_path.stat().st_size
    result = {
        "path": str(out_path),
        "size_bytes": size_bytes,
        "format": "png",
        "captured_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
    }
    if args.get("include_base64"):
        # Operator-driven (the assistant requested embedded bytes).
        # Cap inline payload at 4 MB to avoid blowing up the JSON-RPC
        # response — a 5K monitor screenshot can hit 8-10 MB.
        if size_bytes > 4 * 1024 * 1024:
            result["base64_truncated"] = True
            result["base64"] = None
        else:
            result["base64"] = base64.b64encode(out_path.read_bytes()).decode("ascii")
    return result


def computer_read_clipboard(args: dict) -> dict:
    """Read the current clipboard contents (text only).

    Args: none — clipboard read is parameterless.

    Returns:
      { text, length_chars, read_at }
    """
    _ = args  # explicitly unused
    if platform.system() != "Darwin":
        return _macos_only("computer_read_clipboard")

    try:
        proc = subprocess.run(
            ["pbpaste"],
            capture_output=True,
            timeout=5,
        )
    except subprocess.TimeoutExpired:
        return {
            "isError": True,
            "error": {
                "code": "pbpaste_timeout",
                "message": "pbpaste did not return within 5s",
            },
        }
    if proc.returncode != 0:
        return {
            "isError": True,
            "error": {
                "code": "pbpaste_failed",
                "message": (
                    proc.stderr.decode("utf-8", errors="replace")[:200]
                    or f"pbpaste exited {proc.returncode}"
                ),
            },
        }

    text = proc.stdout.decode("utf-8", errors="replace")
    return {
        "text": text,
        "length_chars": len(text),
        "read_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
    }


# ---------------------------------------------------------------------------
# T3 (B164) — Action tools.
#
# These four cross from "the assistant can see" (T2) to "the assistant
# can act." Per ADR-0048 Decision 2, all four declare
# requires_human_approval=true at the plugin manifest level — the
# operator approves each call by default. A per-(agent, plugin) grant
# (ADR-0043 #1) can downgrade approval for trusted-tier setups.
#
# Posture clamps still apply per ADR-0048 Decision 4:
#   green  → grants decide (approval-gated unless granted-skip)
#   yellow → all non-read calls become PENDING approval
#   red    → all non-read calls REFUSED outright
# Read-only T2 tools bypass posture; T3 action tools do not.
#
# Implementation choices:
#   - osascript with System Events for click + type. Needs the
#     calling process to have macOS Accessibility permission. If
#     missing, surface a clear actionable error (System Settings →
#     Privacy & Security → Accessibility).
#   - `open -a "App Name"` for run_app. Built-in macOS surface; no
#     third-party deps.
#   - `open <url>` for launch_url. Same.
#
# Defense in depth:
#   - Click coordinates clamped to int range; refuses non-numeric
#     args before invoking osascript.
#   - Type text length capped at 4000 chars to bound impact of a
#     runaway loop.
#   - run_app rejects names containing path separators (a 'malicious'
#     constitution might whitelist run_app and then operator grant
#     it; defense-in-depth keeps `open -a` from being tricked into
#     launching an executable file path).
#   - launch_url requires http://, https://, or mailto:// schemes.
#     Blocks file:// and javascript:// which are common attack vectors
#     in browser-bound URL handlers.
# ---------------------------------------------------------------------------


def _osascript_run(script: str, *, timeout: float = 10) -> tuple[int, str, str]:
    """Run an AppleScript via osascript -e. Returns (rc, stdout, stderr)."""
    try:
        proc = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return 124, "", "osascript timed out"
    return (
        proc.returncode,
        proc.stdout.decode("utf-8", errors="replace"),
        proc.stderr.decode("utf-8", errors="replace"),
    )


def computer_click(args: dict) -> dict:
    """Left-click at (x, y) on the screen.

    Args:
      x, y: integer pixel coordinates. Required.

    Returns:
      { clicked_at: 'YYYY-MM-DDTHH:MM:SSZ', x, y } on success.
    """
    if platform.system() != "Darwin":
        return _macos_only("computer_click")

    x = args.get("x")
    y = args.get("y")
    if not isinstance(x, int) or not isinstance(y, int):
        return {
            "isError": True,
            "error": {
                "code": "bad_args",
                "message": "computer_click requires integer x and y arguments",
            },
        }

    # AppleScript via System Events. The escape-quote dance keeps
    # x/y substituted as numbers without ever interpolating strings
    # back into the script body.
    script = f'tell application "System Events" to click at {{{x}, {y}}}'
    rc, _stdout, stderr = _osascript_run(script)
    if rc != 0:
        msg = stderr.strip()[:300] or f"osascript exited {rc}"
        # Common failure: missing Accessibility permission. Recognize
        # the symptom + provide actionable guidance.
        if "1002" in msg or "not authorized" in msg.lower() or "assistive" in msg.lower():
            msg = (
                "macOS denied Accessibility access to the calling process. "
                "Grant it in System Settings → Privacy & Security → "
                "Accessibility for the daemon's parent process. "
                f"Underlying error: {msg}"
            )
        return {
            "isError": True,
            "error": {"code": "click_failed", "message": msg},
        }
    return {
        "clicked_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
        "x": x,
        "y": y,
    }


def computer_type(args: dict) -> dict:
    """Type a string into the focused application.

    Args:
      text: string to type. Required. Capped at 4000 chars.

    Returns:
      { typed_at, length_chars } on success.
    """
    if platform.system() != "Darwin":
        return _macos_only("computer_type")

    text = args.get("text")
    if not isinstance(text, str):
        return {
            "isError": True,
            "error": {
                "code": "bad_args",
                "message": "computer_type requires a 'text' string argument",
            },
        }
    if len(text) > 4000:
        return {
            "isError": True,
            "error": {
                "code": "text_too_long",
                "message": (
                    f"text length {len(text)} exceeds 4000-char cap. "
                    f"Bound the input or use multiple computer_type calls "
                    f"for legitimate long inputs."
                ),
            },
        }

    # Escape backslash + double-quote for safe AppleScript-string
    # embedding. Newlines pass through as-is (System Events keystroke
    # interprets \n as a literal Return key when typed).
    safe = text.replace("\\", "\\\\").replace('"', '\\"')
    script = f'tell application "System Events" to keystroke "{safe}"'
    rc, _stdout, stderr = _osascript_run(script)
    if rc != 0:
        msg = stderr.strip()[:300] or f"osascript exited {rc}"
        if "1002" in msg or "not authorized" in msg.lower() or "assistive" in msg.lower():
            msg = (
                "macOS denied Accessibility access to the calling process. "
                "Grant it in System Settings → Privacy & Security → "
                "Accessibility. " + msg
            )
        return {
            "isError": True,
            "error": {"code": "type_failed", "message": msg},
        }
    return {
        "typed_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
        "length_chars": len(text),
    }


def computer_run_app(args: dict) -> dict:
    """Launch an app by display name via `open -a`.

    Args:
      app_name: string app name (e.g. 'Safari', 'Mail', 'Visual Studio Code').
                Must NOT contain '/' — defense-in-depth against
                operator-granted run_app being tricked into launching
                an arbitrary executable path.

    Returns:
      { launched_at, app_name } on success.
    """
    if platform.system() != "Darwin":
        return _macos_only("computer_run_app")

    app_name = args.get("app_name")
    if not isinstance(app_name, str) or not app_name.strip():
        return {
            "isError": True,
            "error": {
                "code": "bad_args",
                "message": "computer_run_app requires non-empty 'app_name' string",
            },
        }
    if "/" in app_name or "\x00" in app_name:
        return {
            "isError": True,
            "error": {
                "code": "bad_app_name",
                "message": (
                    "app_name must not contain '/' or null byte. Use the "
                    "display name (e.g., 'Safari'), not a file path. "
                    "computer_run_app is for opening apps; arbitrary "
                    "binary execution is not its scope."
                ),
            },
        }

    try:
        proc = subprocess.run(
            ["open", "-a", app_name],
            capture_output=True,
            timeout=10,
        )
    except subprocess.TimeoutExpired:
        return {
            "isError": True,
            "error": {
                "code": "open_timeout",
                "message": f"open -a {app_name!r} did not return within 10s",
            },
        }
    if proc.returncode != 0:
        return {
            "isError": True,
            "error": {
                "code": "open_failed",
                "message": (
                    proc.stderr.decode("utf-8", errors="replace")[:200]
                    or f"open exited {proc.returncode}"
                ),
            },
        }
    return {
        "launched_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
        "app_name": app_name,
    }


def computer_launch_url(args: dict) -> dict:
    """Open a URL in the default browser via `open <url>`.

    Args:
      url: string URL. Must use http://, https://, or mailto:// scheme.
           file:// and javascript:// are refused — those are common
           XSS / local-file-exfil attack vectors when a URL handler
           is exposed to an automation surface.

    Returns:
      { launched_at, url } on success.
    """
    if platform.system() != "Darwin":
        return _macos_only("computer_launch_url")

    url = args.get("url")
    if not isinstance(url, str) or not url.strip():
        return {
            "isError": True,
            "error": {
                "code": "bad_args",
                "message": "computer_launch_url requires a non-empty 'url' string",
            },
        }

    allowed_prefixes = ("http://", "https://", "mailto:")
    if not any(url.startswith(p) for p in allowed_prefixes):
        return {
            "isError": True,
            "error": {
                "code": "scheme_disallowed",
                "message": (
                    f"URL scheme not in allowlist {allowed_prefixes}. "
                    f"file:// and javascript:// are explicitly refused — "
                    f"they're common attack vectors. Pass a normal "
                    f"http(s):// or mailto: URL."
                ),
            },
        }

    try:
        proc = subprocess.run(
            ["open", url],
            capture_output=True,
            timeout=10,
        )
    except subprocess.TimeoutExpired:
        return {
            "isError": True,
            "error": {
                "code": "open_timeout",
                "message": f"open {url!r} did not return within 10s",
            },
        }
    if proc.returncode != 0:
        return {
            "isError": True,
            "error": {
                "code": "open_failed",
                "message": (
                    proc.stderr.decode("utf-8", errors="replace")[:200]
                    or f"open exited {proc.returncode}"
                ),
            },
        }
    return {
        "launched_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
        "url": url,
    }


# ---------------------------------------------------------------------------
# JSON-RPC dispatch
# ---------------------------------------------------------------------------

TOOLS = {
    "computer_screenshot": computer_screenshot,
    "computer_read_clipboard": computer_read_clipboard,
    # T3 (B164) — action tools.
    "computer_click": computer_click,
    "computer_type": computer_type,
    "computer_run_app": computer_run_app,
    "computer_launch_url": computer_launch_url,
}


def handle(request: dict) -> dict:
    """Build a JSON-RPC response for the given request."""
    req_id = request.get("id", 1)
    method = request.get("method", "")

    if method == "tools/list":
        # Optional MCP method — Forest's mcp_call.v1 doesn't currently
        # invoke this on each call (the plugin manifest is the source
        # of truth for capabilities), but supporting it lets an
        # operator hand-debug the server with a stock MCP client.
        return {
            "jsonrpc": "2.0",
            "id": req_id,
            "result": {
                "tools": [
                    {
                        "name": "computer_screenshot",
                        "description": "Capture the visible screen via macOS screencapture; return path + size.",
                    },
                    {
                        "name": "computer_read_clipboard",
                        "description": "Read the current clipboard contents (text only) via macOS pbpaste.",
                    },
                    {
                        "name": "computer_click",
                        "description": "Left-click at integer (x, y) coordinates via osascript System Events.",
                    },
                    {
                        "name": "computer_type",
                        "description": "Type a string (max 4000 chars) into the focused app via osascript System Events.",
                    },
                    {
                        "name": "computer_run_app",
                        "description": "Launch an app by display name via `open -a`. No file paths.",
                    },
                    {
                        "name": "computer_launch_url",
                        "description": "Open a URL via `open`. http://, https://, mailto: only.",
                    },
                ],
            },
        }

    if method != "tools/call":
        return {
            "jsonrpc": "2.0",
            "id": req_id,
            "error": {
                "code": -32601,
                "message": f"method not found: {method!r}",
            },
        }

    params = request.get("params") or {}
    name = params.get("name", "")
    arguments = params.get("arguments") or {}

    impl = TOOLS.get(name)
    if impl is None:
        return {
            "jsonrpc": "2.0",
            "id": req_id,
            "error": {
                "code": -32602,
                "message": (
                    f"unknown tool: {name!r}. Known tools: "
                    f"{sorted(TOOLS)}"
                ),
            },
        }

    try:
        result = impl(arguments)
    except Exception as e:                    # noqa: BLE001
        return {
            "jsonrpc": "2.0",
            "id": req_id,
            "error": {
                "code": -32000,
                "message": f"tool {name!r} raised: {type(e).__name__}: {e}",
            },
        }
    return {
        "jsonrpc": "2.0",
        "id": req_id,
        "result": result,
    }


def main() -> int:
    line = sys.stdin.readline()
    if not line.strip():
        sys.stderr.write("soulux-computer-control: empty stdin (no JSON-RPC request)\n")
        return 1
    try:
        request = json.loads(line)
    except json.JSONDecodeError as e:
        response = {
            "jsonrpc": "2.0",
            "id": None,
            "error": {
                "code": -32700,
                "message": f"parse error: {e}",
            },
        }
        sys.stdout.write(json.dumps(response) + "\n")
        return 1
    response = handle(request)
    sys.stdout.write(json.dumps(response) + "\n")
    sys.stdout.flush()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
