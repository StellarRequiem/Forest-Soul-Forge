{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forest Soul Forge",
  "version": "0.5.0-dev",
  "identifier": "com.stellarrequiem.forest-soul-forge",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../../frontend",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Forest Soul Forge",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "url": "/?api=http://127.0.0.1:7423",
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first agent foundry",
    "longDescription": "Forest Soul Forge is a sovereign, local-first agent foundry. Drag trait sliders to build agents with cryptographically-signed identity, quantified personality, tamper-evident behavior logs, and constitutional rulebooks. Every action lands in a hash-chained audit log on your machine. No cloud, no telemetry."
  },
  "plugins": {}
}
