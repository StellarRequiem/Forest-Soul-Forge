# Forest Soul Forge — environment overrides for docker compose.
#
# Copy to .env at the repo root:   cp .env.example .env
# Compose picks it up automatically. Nothing here is required — defaults
# work out of the box. Uncomment only the knobs you need.
#
# Everything the daemon accepts is documented in
# src/forest_soul_forge/daemon/config.py with a matching FSF_ env var.

# ---- server -----------------------------------------------------------
# FSF_HOST=0.0.0.0          # Inside container, stays 0.0.0.0 — host
#                           # exposure is controlled by compose port map.
# FSF_PORT=7423

# ---- auth -------------------------------------------------------------
# Leave unset for a frictionless local dev boot. SET this before exposing
# the daemon beyond loopback — the token gates every write endpoint.
# FSF_API_TOKEN=

# ---- active provider --------------------------------------------------
# FSF_DEFAULT_PROVIDER=local       # or "frontier" (requires key below)

# ---- local provider (Ollama) -----------------------------------------
# If using the bundled ollama service (--profile llm), the default URL
# below already points at it. If Ollama runs on your host instead, use:
#   macOS / Windows Docker Desktop:  http://host.docker.internal:11434
#   Linux:                           http://172.17.0.1:11434 (docker0)
# FSF_LOCAL_BASE_URL=http://ollama:11434
# FSF_LOCAL_MODEL=llama3.1:8b
# FSF_LOCAL_TIMEOUT_S=60

# ---- frontier provider (opt-in) --------------------------------------
# FSF_FRONTIER_ENABLED=false
# FSF_FRONTIER_BASE_URL=https://api.openai.com
# FSF_FRONTIER_API_KEY=
# FSF_FRONTIER_MODEL=gpt-4o-mini

# ---- CORS -------------------------------------------------------------
# Baked defaults accept the frontend container's published origin
# (http://127.0.0.1:5173). If you serve the frontend from somewhere else,
# override here. Must be a JSON array.
# FSF_CORS_ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
