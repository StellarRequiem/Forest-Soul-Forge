# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Frontend (SoulUX userspace) — Vitest + jsdom scaffold from Burst 133.
# package.json + vitest.config.js + tests/ are tracked; the install
# tree and coverage output are not.
frontend/node_modules/
frontend/tests/coverage/
frontend/.vitest-cache/
build/
develop-eggs/
# F8: dist/ used to be a blanket ignore (Python sdist convention). We
# now ship a build.command + README.md from there, so keep the dir
# tracked and only ignore the actual built archives (handled below).
# dist/                 ← removed
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local agent state — never commit personal agent configs or audit chains
agents/instances/
audit_logs/
*.audit.jsonl
# Operator's live chain lives at audit/chain.jsonl — never commit it.
# The demo fixture at examples/audit_chain.jsonl (underscore) is intentionally tracked.
audit/chain.jsonl
soul_generated/
local_state/
# SQLite registry is an index rebuildable from canonical artifacts — never commit.
registry.sqlite
registry.sqlite-shm
registry.sqlite-wal

# Streamlit
.streamlit/secrets.toml

# Local-dev launcher runtime state (run.command writes logs + pidfiles here)
.run/

# ADR-0041 set-and-forget orchestrator config — per-install operator
# state (instance_ids are unique per Forest installation). Ship the
# .example for shape; the activated file is local-only.
config/scheduled_tasks.yaml

# Session-specific diagnostic dumps (operator-side tools dump host
# log fragments here for debugging — ephemeral, not source-of-truth).
_diagnostic_*.txt

# Docker
docker-compose.override.yml

# Compose runtime state — registry, audit, generated souls, ollama cache.
# Keep the directory itself (via data/.gitkeep) but ignore everything in it.
data/*
!data/.gitkeep

# F7: isolated demo state (start-demo.command points the daemon here).
# load-scenario.command --target=demo unpacks scenarios into this dir.
# We never commit this — the canonical scenarios live in scenarios/.
demo/

# F4 + F7: backup files from reset.command + load-scenario.command.
# These accumulate as you rehearse; clean them out manually when you
# don't need them anymore.
*.bak.[0-9]*

# F8: built distribution archives. Keep dist/ + dist/build.command +
# dist/README.md tracked, but never commit the actual .zip outputs.
dist/forest-soul-forge-*.zip

# ADR-0042 T3 (Burst 99): Tauri/Rust build artifacts. The Rust
# crate's target/ dir can hit several GB; never commit it.
# Cargo.lock IS tracked because this is a binary crate (not a
# library) — Tauri's docs explicitly recommend committing it for
# reproducible release builds.
apps/desktop/target/
apps/desktop/gen/

# Real Tauri icons — generated locally via `cargo tauri icon
# <source.png>`. Until a 1024×1024 source PNG exists in the repo
# (or in a tracked design directory), the icons/ dir holds only
# the placeholder README. Once real icons land we can revisit
# whether they're tracked or build-time-generated.
apps/desktop/icons/*.png
apps/desktop/icons/*.icns
apps/desktop/icons/*.ico
!apps/desktop/icons/README.md

# ADR-0042 T4 (Burst 101): bundled daemon binaries. Each
# developer / CI builds locally for their arch via
# dist/build-daemon-binary.command — never committed because
# they're 50-80MB and arch-specific.
apps/desktop/binaries/

# PyInstaller build artifacts. dist/build-daemon-binary.command
# writes to dist/build/ (intermediate) and dist/dist/ (final
# binary). Both are operator-local outputs.
dist/build/
dist/dist/
