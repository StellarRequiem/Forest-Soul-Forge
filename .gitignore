.ruff_cache/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local agent state — never commit personal agent configs or audit chains
agents/instances/
audit_logs/
*.audit.jsonl
# Operator's live chain lives at audit/chain.jsonl — never commit it.
# The demo fixture at examples/audit_chain.jsonl (underscore) is intentionally tracked.
audit/chain.jsonl
soul_generated/
local_state/
# SQLite registry is an index rebuildable from canonical artifacts — never commit.
registry.sqlite
registry.sqlite-shm
registry.sqlite-wal

# Streamlit
.streamlit/secrets.toml

# Local-dev launcher runtime state (run.command writes logs + pidfiles here)
.run/

# Docker
docker-compose.override.yml

# Compose runtime state — registry, audit, generated souls, ollama cache.
# Keep the directory itself (via data/.gitkeep) but ignore everything in it.
data/*
!data/.gitkeep

# F7: isolated demo state (start-demo.command points the daemon here).
# load-scenario.command --target=demo unpacks scenarios into this dir.
# We never commit this — the canonical scenarios live in scenarios/.
demo/

# F4 + F7: backup files from reset.command + load-scenario.command.
# These accumulate as you rehearse; clean them out manually when you
# don't need them anymore.
*.bak.[0-9]*
